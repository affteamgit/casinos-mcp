# Token for the internal Casino Kings API (passed as &token= to upstream)
CASINO_API_TOKEN="your-token-here"

# Auth0 OAuth (optional locally; required in production)
# When all three are set, the MCP server requires a valid Auth0 access token.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-project.vercel.app/api/mcp
MCP_SERVER_URL=https://your-project.vercel.app/api/mcp
